# ─────────────────────────────────────────────────────────────
# Mycotopo — environment variables
# Copy this file to `.env` and fill in values as needed.
# `.env` is gitignored; `.env.example` is committed as a template.
# ─────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────
# Override the default data directory (absolute path recommended).
# Defaults to <project_root>/data if unset.
# MYCOTOPO_DATA_DIR=D:/mycotopo-data

# ── Weather APIs (Phase 1 NB 05, Phase 3 onwards) ────────────
# Météo-France Portail Données Publiques — requires registration.
# https://portail-api.meteofrance.fr/
METEO_FRANCE_API_KEY=

# Open-Meteo — no key required for non-commercial use.
# Leave empty unless you subscribe to the commercial tier.
OPEN_METEO_API_KEY=

# ── IGN Géoplateforme (Phase 1 NB 01, 03, 04) ────────────────
# Most IGN open data is key-free since the Géoplateforme migration,
# but some endpoints still accept a key for higher quotas.
IGN_API_KEY=

# ── FastAPI backend (Phase 4) ────────────────────────────────
# Host/port for the local dev server.
MYCOTOPO_API_HOST=127.0.0.1
MYCOTOPO_API_PORT=8000

# Comma-separated origins allowed by CORS (frontend dev server).
MYCOTOPO_CORS_ORIGINS=http://localhost:5173

# ── Logging ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
MYCOTOPO_LOG_LEVEL=INFO
